generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EventCategory {
  CONFERENCE
  WORKSHOP
  MEETUP
  CONCERT
  SPORT
  OTHER
}

model Event {
  id          Int           @id @default(autoincrement())
  title       String
  description String
  date        DateTime
  location    String
  category    EventCategory

  latitude    Float?
  longitude   Float?

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([category])
  @@index([date])
}